# Sentifish — Web Search Evaluation Platform
# Copy to .env and fill in values

# Environment
ENV=dev

# Server
SERVER_PORT=4010

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4010

# Search Providers (enable the ones you need)
BRAVE_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
TINYFISH_API_KEY=

# Results storage directory
RESULTS_DIR=./results
